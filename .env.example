# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# Some variables are host-specific (marked below)

# =============================================================================
# TAILSCALE (Required on ALL hosts)
# =============================================================================
# Tailscale authkey for VPN mesh network
# Get from: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hostname for this machine in Tailscale network
# Use different names for each host:
#   rocketman: TAILSCALE_HOSTNAME=rocketman
#   sweetpaintedlady: TAILSCALE_HOSTNAME=sweetpaintedlady
TAILSCALE_HOSTNAME=composeyourself

# Additional Tailscale arguments (optional)
# Example: --advertise-exit-node --accept-dns=true
TS_EXTRA_ARGS=

# =============================================================================
# ROCKETMAN HOST (Raspberry Pi) - docker-compose.rocketman.yml
# =============================================================================

# Immich Photo Management
# -----------------------
# The location where your uploaded files are stored
UPLOAD_LOCATION=./library

# The location where your database files are stored
# Network shares are not supported for the database
DB_DATA_LOCATION=./postgres

# Timezone for Immich
TZ=America/Toronto

# Immich version - pin to specific version like "v2.1.0" or use "release"
IMMICH_VERSION=v2.7.5

# PostgreSQL credentials (change these!)
# Use only A-Za-z0-9 characters, no special characters or spaces
DB_PASSWORD=changeme123
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# yt-dlp Web Interface
# --------------------
# Download directories (these are container paths, host paths are in compose)
DOWNLOAD_DIR=/downloads
AUDIO_DIR=/downloads/audio
LOG_FILE=/app/logs/yt-dlp-web.log
PORT=8080

# Discord Announcements Service
# -----------------------------
# Discord webhook URL for sending announcements
# Create at: https://support.discord.com/hc/en-us/articles/228383668
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx

# =============================================================================
# SWEETPAINTEDLADY HOST (DigitalOcean) - docker-compose.sweetpaintedlady.yml
# =============================================================================

# Domain Configuration
# --------------------
# Domain name for sweetpaintedlady (must have DNS A record pointing to server)
DOMAIN=example.com
SUBDOMAIN=app

# Open WebUI
# ----------
# OpenRouter API key for AI chat
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default models for Open WebUI (comma-separated)
# Example: openai/gpt-4o,anthropic/claude-3.5-sonnet
# NOTE: This env var is only honoured on FIRST boot (PersistentConfig). After
# that, the declared default in services/agenticui-config/config.json takes over
# (copied by generate_config.sh into the data dir before each deploy).
OPENWEBUI_DEFAULT_MODELS=

# OpenWebUI admin API key — used by scripts/seed-openwebui.sh to import the
# model presets in services/agenticui-config/models.json after each deploy.
#
# One-time bootstrap (required before preset seeding works):
#   1. Deploy once with this key empty — the seed script will skip gracefully.
#   2. Log in to OpenWebUI via Authelia as an openwebui-admin user.
#   3. Go to Settings > Account > API Keys > create a new key (sk-...).
#   4. Paste it here and re-deploy. Subsequent deploys auto-seed presets.
#
# The import endpoint upserts by model id, so re-running is always safe.
# ENABLE_API_KEYS=true is already set in docker-compose.sweetpaintedlady.yml.
OPENWEBUI_API_KEY=

# Authelia MFA Authentication
# ---------------------------
# Generate these secrets with: openssl rand -hex 32

# JWT secret for token signing
AUTHELIA_JWT_SECRET=

# Session encryption key
AUTHELIA_SESSION_SECRET=

# Database encryption key
AUTHELIA_STORAGE_ENCRYPTION_KEY=

# SMTP settings for Authelia (password resets, 2FA notifications)
# Using Fastmail as example - adjust for your provider
AUTHELIA_SMTP_HOST=smtp.fastmail.com
AUTHELIA_SMTP_PORT=587
AUTHELIA_SMTP_USERNAME=your-email@fastmail.com
# Generate app-specific password in Fastmail: Settings → Privacy & Security
AUTHELIA_SMTP_PASSWORD=your-app-specific-password
AUTHELIA_SMTP_SENDER="Authelia <auth@yourdomain.com>"

# Admin email for Authelia user account (password resets will be sent here)
AUTHELIA_ADMIN_EMAIL=your-email@fastmail.com

# OIDC Configuration
# ------------------
# Client secret for OpenWebUI OIDC authentication with Authelia
# Generate with: openssl rand -hex 32
OPENWEBUI_OIDC_SECRET=

WEBUI_URL=https://ai.example.com
ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true
OAUTH_CLIENT_ID=open-webui
# docker run --rm authelia/authelia:latest authelia crypto rand --length 64 --charset alphanumeric | sed -e "s|Random Value: ||"
OAUTH_CLIENT_SECRET=LspSCy77kL1hnFyF58lgbECttWnPHUBKnZH80ahliKvCEd69gW43Y8xRbEHm14p0
OAUTH_PROVIDER_NAME=Authelia
OAUTH_SCOPES=openid email profile groups
ENABLE_OAUTH_ROLE_MANAGEMENT=true
OAUTH_ALLOWED_ROLES=openwebui,openwebui-admin
OAUTH_ADMIN_ROLES=openwebui-admin
OAUTH_ROLES_CLAIM=groups
OAUTH_CODE_CHALLENGE_METHOD=S256

# =============================================================================
# OBSERVABILITY / OPENTELEMETRY (rocketman) - services/signoz/
# =============================================================================
# See OTEL_SPEC.md and OTEL_PLAN.md. The SigNoz stack is reachable ONLY over
# Tailscale. Pinned image versions are recorded in services/signoz/VERSIONS.md.

# --- Image version pins ---
SIGNOZ_VERSION=v0.129.0                     # signoz/signoz (UI + query + alertmanager)
SIGNOZ_OTEL_COLLECTOR_VERSION=v0.144.5      # signoz-otel-collector + schema migrator (bump as a pair)
CLICKHOUSE_VERSION=25.5.6                   # 24.1.2 too old for v0.144.5 migrator JSON(max_dynamic_paths) DDL
ZOOKEEPER_VERSION=3.7.1
OTELCOL_CONTRIB_VERSION=0.135.0             # sweetpaintedlady edge collector (otel/opentelemetry-collector-contrib)
CADVISOR_VERSION=v0.57.0
NODE_EXPORTER_VERSION=v1.11.1
POSTGRES_EXPORTER_VERSION=v0.19.1
REDIS_EXPORTER_VERSION=v1.86.0

# --- Storage ---
# Where SigNoz/ClickHouse persists data on rocketman.
SIGNOZ_DATA_LOCATION=/mnt/storage/signoz

# --- Network binding (Tailscale) ---
# Bind the SigNoz UI (:8080) and OTLP ingest (:4317/:4318) to a specific
# interface. Set this to rocketman's Tailscale interface IP (e.g. 100.x.y.z)
# so telemetry is reachable ONLY over the tailnet, never the public/LAN IP.
# Leave at 0.0.0.0 only for local development.
# NOTE: with the 0.0.0.0 default the SigNoz UI (:8080) collides with yt-dlp;
# set a real tailnet IP on rocketman.
SIGNOZ_BIND_ADDR=0.0.0.0

# Bind app services exposed over Tailscale (swole :8090, announcements :8091) to
# a specific interface. Set to rocketman's Tailscale IP so they are reachable
# ONLY over the tailnet. Defaults to 127.0.0.1 (local-only) for dev/other hosts.
# Required because tailscale runs in kernel TUN mode (TS_USERSPACE=false), which
# no longer proxies inbound tailnet connections to 127.0.0.1.
TAILNET_BIND_ADDR=127.0.0.1

# --- Auth ---
# Strong secret for SigNoz token signing. Generate with: openssl rand -hex 32
# Do NOT ship the upstream default ("secret") to production.
SIGNOZ_JWT_SECRET=

# --- Retention (configured via SigNoz UI/ClickHouse TTL; see Phase 6) ---
SIGNOZ_LOGS_RETENTION_DAYS=14
SIGNOZ_TRACES_RETENTION_DAYS=7
SIGNOZ_METRICS_RETENTION_DAYS=30

# --- Cross-host OTLP (used by the sweetpaintedlady edge collector) ---
# Tailscale MagicDNS name (or IP) of rocketman, where SPL ships telemetry.
ROCKETMAN_TAILSCALE_HOST=rocketman
ROCKETMAN_OTLP_GRPC_PORT=4317
ROCKETMAN_OTLP_HTTP_PORT=4318

# Base OTel resource attributes applied to instrumented services.
OTEL_RESOURCE_ATTRIBUTES_BASE=deployment.environment=prod

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Never commit this file with real values to git
# 2. Use strong, unique passwords for all services
# 3. Keep secrets backed up securely (password manager)
# 4. Rotate secrets periodically
# 5. Use app-specific passwords for email/SMTP, not your main password
