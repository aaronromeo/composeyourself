        const showNamingHelp = document.getElementById('show-naming-help');
        const hideNamingHelp = document.getElementById('hide-naming-help');
        const namingHelp = document.getElementById('naming-help');
        
        // Utility functions
        function showAlert(message, type = 'success') {
            alertContainer.innerHTML = `<div class="alert ${type}">${message}</div>`;
            setTimeout(() => {
                alertContainer.innerHTML = '';
            }, 5000);
        }
        
        function formatBytes(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }
        
        function formatDuration(startTime) {
            const start = new Date(startTime);
            const now = new Date();
            const diff = Math.floor((now - start) / 1000);
            
            if (diff < 60) return `${diff}s`;
            if (diff < 3600) return `${Math.floor(diff / 60)}m ${diff % 60}s`;
            return `${Math.floor(diff / 3600)}h ${Math.floor((diff % 3600) / 60)}m`;
        }
        
        // Audio naming patterns
        const namingPatterns = {
            'default': '%(uploader)s/%(title)s.%(ext)s',
            'artist-title': '%(uploader)s - %(title)s.%(ext)s',
            'album-format': '%(uploader)s-%(playlist)s/%(uploader)s-%(title)s.%(ext)s',
            'date-title': '%(upload_date>%Y-%m-%d)s - %(uploader)s - %(title)s.%(ext)s',
            'title-only': '%(title)s.%(ext)s',
            'title-id': '%(title)s [%(id)s].%(ext)s',
            'playlist': '%(playlist|%(uploader)s)s/%(playlist_index|00)02d - %(title)s.%(ext)s',
            'duration': '%(uploader)s/[%(duration_string)s] %(title)s.%(ext)s'
        };

        // Event listeners
        audioOnlyCheckbox.addEventListener('change', function() {
            audioOptions.style.display = this.checked ? 'block' : 'none';
        });

        audioNaming.addEventListener('change', function() {
            if (this.value !== 'custom' && this.value in namingPatterns) {
                const pattern = namingPatterns[this.value];
                const currentArgs = customArgs.value.trim();

                // Remove existing --output arguments
                let newArgs = currentArgs.replace(/--output\s+"[^"]*"/g, '').replace(/--output\s+\S+/g, '').trim();

                // Add new output pattern
                if (newArgs) {
                    newArgs += ' ';
                }
                newArgs += `--output "${pattern}"`;

                customArgs.value = newArgs;
            }
        });

        showNamingHelp.addEventListener('click', function(e) {
            e.preventDefault();
            namingHelp.style.display = 'block';
        });

        hideNamingHelp.addEventListener('click', function(e) {
            e.preventDefault();
            namingHelp.style.display = 'none';
        });

        // Form submission
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (isSubmitting) return;
            isSubmitting = true;
            downloadBtn.disabled = true;
            downloadBtn.textContent = 'Adding...';
            
            const formData = new FormData(form);
            const data = {
                url: formData.get('url'),
                audio_only: formData.has('audio_only'),
                custom_args: formData.get('custom_args')
            };
            
            try {
                const response = await fetch('/api/download', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (response.ok) {
                    showAlert(`Download added to queue! Queue size: ${result.queue_size}`, 'success');
                    form.reset();
                } else {
                    showAlert(result.error || 'Failed to add download', 'error');
                }
            } catch (error) {
                showAlert('Network error: ' + error.message, 'error');
            } finally {
                isSubmitting = false;
                downloadBtn.disabled = false;
                downloadBtn.textContent = 'Add to Queue';
            }
        });
        
        // Update status
        async function updateStatus() {
            try {
                const response = await fetch('/api/status');
                const data = await response.json();
                
                // Update active downloads
                if (Object.keys(data.active_downloads).length === 0) {
                    activeDownloads.innerHTML = '<p>No active downloads</p>';
                } else {
                    activeDownloads.innerHTML = Object.entries(data.active_downloads)
                        .map(([id, download]) => `
                            <div class="download-item ${download.status}">
                                <strong>Status:</strong> ${download.status} 
                                ${download.audio_only ? '(Audio Only)' : ''}
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: ${download.progress}%"></div>
                                </div>
                                <div>${download.progress.toFixed(1)}% - ${formatDuration(download.start_time)}</div>
                                <div class="url-display">${download.url}</div>
                            </div>
                        `).join('');
                }
                
                // Update history
                if (data.history.length === 0) {
                    downloadHistory.innerHTML = '<p>No recent downloads</p>';
                } else {
                    downloadHistory.innerHTML = data.history
                        .map(download => `
                            <div class="download-item ${download.status}">
                                <strong>Status:</strong> ${download.status}
                                ${download.audio_only ? '(Audio Only)' : ''}
                                <div class="url-display">${download.url}</div>
                            </div>
                        `).join('');
                }
                
            } catch (error) {
                console.error('Failed to update status:', error);
            }
        }
        
        // Update files list
        async function updateFiles() {
            try {
                const response = await fetch('/api/files');
                const files = await response.json();
                
                if (files.length === 0) {
                    filesList.innerHTML = '<p>No files downloaded yet</p>';
                } else {
                    filesList.innerHTML = files
                        .sort((a, b) => new Date(b.modified) - new Date(a.modified))
                        .map(file => `
                            <div class="file-item">
                                <div class="file-name">
                                    <a href="/downloads/${file.path}" target="_blank">${file.name}</a>
                                </div>
                                <div class="file-size">${formatBytes(file.size)}</div>
                            </div>
                        `).join('');
                }
            } catch (error) {
                filesList.innerHTML = '<p>Error loading files</p>';
                console.error('Failed to update files:', error);
            }
        }
        
        // Initialize and start polling
        updateStatus();
        updateFiles();
        
        // Poll for updates every 2 seconds
        setInterval(updateStatus, 2000);
        setInterval(updateFiles, 10000); // Files update less frequently
    </script>
</body>
</html>
