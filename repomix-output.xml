#!/usr/bin/env python3
"""
Simple yt-dlp Web Interface for Raspberry Pi
A lightweight Flask web app for downloading videos with yt-dlp
"""

import os
import json
import subprocess
import threading
import time
from datetime import datetime
from flask import Flask, render_template, request, jsonify, send_from_directory
from werkzeug.serving import make_server
import queue
import logging

app = Flask(__name__)
app.secret_key = 'your-secret-key-change-this'

# Configuration from environment variables
DOWNLOAD_DIR = os.getenv('DOWNLOAD_DIR', '/downloads')
AUDIO_DIR = os.getenv('AUDIO_DIR', '/downloads/audio')
LOG_FILE = os.getenv('LOG_FILE', '/app/logs/yt-dlp-web.log')
PORT = int(os.getenv('PORT', 8080))

# Global variables
download_queue = queue.Queue()
active_downloads = {}
download_history = []

# Setup logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler(LOG_FILE),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

def ensure_directories():
    """Create necessary directories"""
    os.makedirs(DOWNLOAD_DIR, exist_ok=True)
    os.makedirs(AUDIO_DIR, exist_ok=True)
    logger.info(f"Directories ensured: {DOWNLOAD_DIR}, {AUDIO_DIR}")

def download_worker():
    """Background worker to process download queue"""
    while True:
        try:
            if not download_queue.empty():
                download_info = download_queue.get()
                process_download(download_info)
                download_queue.task_done()
            time.sleep(1)
        except Exception as e:
            logger.error(f"Download worker error: {e}")

def process_download(download_info):
    """Process a single download"""
    url = download_info['url']
    audio_only = download_info.get('audio_only', False)
    custom_args = download_info.get('custom_args', '')

    download_id = f"dl_{int(time.time())}"
    active_downloads[download_id] = {
        'url': url,
        'status': 'downloading',
        'progress': 0,
        'start_time': datetime.now(),
        'audio_only': audio_only
    }

    try:
        # Build yt-dlp command
        cmd = ['yt-dlp']

        # Check if custom args contain output template
        has_custom_output = '--output' in custom_args or '-o' in custom_args

        if audio_only:
            cmd.extend([
                '--extract-audio',
                '--audio-format', 'mp3'
            ])

            # Only add default output if no custom output specified
            if not has_custom_output:
                cmd.extend(['--output', f'{AUDIO_DIR}/%(uploader)s/%(title)s.%(ext)s'])
        else:
            # Only add default output if no custom output specified
            if not has_custom_output:
                cmd.extend(['--output', f'{DOWNLOAD_DIR}/%(uploader)s/%(title)s.%(ext)s'])

        # Add custom arguments if provided
        if custom_args:
            # Handle quoted arguments properly
            import shlex
            try:
                custom_args_list = shlex.split(custom_args)
                cmd.extend(custom_args_list)
                logger.info(f"Added custom args: {custom_args_list}")
            except ValueError as e:
                logger.warning(f"Failed to parse custom args with shlex: {e}")
                # Fallback to simple split if shlex fails
                cmd.extend(custom_args.split())

        cmd.append(url)
        
        logger.info(f"Starting download: {' '.join(cmd)}")
        
        # Run yt-dlp
        process = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            universal_newlines=True,
            bufsize=1
        )
        
        # Monitor progress
        for line in process.stdout:
            if '[download]' in line and '%' in line:
                try:
                    # Extract progress percentage
                    progress_str = line.split('%')[0].split()[-1]
                    progress = float(progress_str)
                    active_downloads[download_id]['progress'] = progress
                except:
                    pass
            logger.info(f"yt-dlp: {line.strip()}")
        
        process.wait()
        
        if process.returncode == 0:
            active_downloads[download_id]['status'] = 'completed'
            active_downloads[download_id]['progress'] = 100
            logger.info(f"Download completed: {url}")
        else:
            active_downloads[download_id]['status'] = 'failed'
            logger.error(f"Download failed: {url}")
            
    except Exception as e:
        active_downloads[download_id]['status'] = 'failed'
        logger.error(f"Download error for {url}: {e}")
    
    # Move to history after 5 minutes
    threading.Timer(300, lambda: move_to_history(download_id)).start()

def move_to_history(download_id):
    """Move completed download to history"""
    if download_id in active_downloads:
        download_history.append(active_downloads[download_id])
        del active_downloads[download_id]
        # Keep only last 50 items in history
        if len(download_history) > 50:
            download_history.pop(0)

@app.route('/')
def index():
    """Main page"""
    return render_template('index.html')

@app.route('/api/download', methods=['POST'])
def add_download():
    """Add a new download to the queue"""
    data = request.get_json()
    url = data.get('url', '').strip()
    
    if not url:
        return jsonify({'error': 'URL is required'}), 400
    
    download_info = {
        'url': url,
        'audio_only': data.get('audio_only', False),
        'custom_args': data.get('custom_args', '')
    }
    
    download_queue.put(download_info)
    logger.info(f"Added to queue: {url}")
    
    return jsonify({'message': 'Download added to queue', 'queue_size': download_queue.qsize()})

@app.route('/api/status')
def get_status():
    """Get current download status"""
    return jsonify({
        'active_downloads': active_downloads,
        'queue_size': download_queue.qsize(),
        'history': download_history[-10:]  # Last 10 items
    })

@app.route('/api/files')
def list_files():
    """List downloaded files"""
    files = []
    try:
        for root, dirs, filenames in os.walk(DOWNLOAD_DIR):
            for filename in filenames:
                if not filename.startswith('.'):
                    filepath = os.path.join(root, filename)
                    rel_path = os.path.relpath(filepath, DOWNLOAD_DIR)
                    size = os.path.getsize(filepath)
                    mtime = os.path.getmtime(filepath)
                    files.append({
                        'name': filename,
                        'path': rel_path,
                        'size': size,
                        'modified': datetime.fromtimestamp(mtime).isoformat()
                    })
    except Exception as e:
        logger.error(f"Error listing files: {e}")
    
    return jsonify(files)

@app.route('/downloads/<path:filename>')
def download_file(filename):
    """Serve downloaded files"""
    return send_from_directory(DOWNLOAD_DIR, filename)

if __name__ == '__main__':
    ensure_directories()
    
    # Start download worker thread
    worker_thread = threading.Thread(target=download_worker, daemon=True)
    worker_thread.start()
    
    logger.info(f"Starting yt-dlp web interface on port {PORT}")
    logger.info(f"Download directory: {DOWNLOAD_DIR}")
    logger.info(f"Audio directory: {AUDIO_DIR}")
    
    app.run(host='0.0.0.0', port=PORT, debug=False)
